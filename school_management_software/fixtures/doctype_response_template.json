{
  "doctype": "DocType",
  "name": "Response Template",
  "module": "Education",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "is_calendar_and_gantt": 0,
  "editable_grid": 1,
  "quick_entry": 0,
  "track_changes": 0,
  "track_seen": 0,
  "track_views": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "By fieldname",
  "autoname": "field:title",
  "allow_rename": 1,
  "description": "Configurable response templates for enquiries, complaints, and communications",
  "title_field": "title",
  "search_fields": "title,category",
  "sort_field": "modified",
  "sort_order": "DESC",
  "default_view": "List",
  "icon": "",
  "image_field": "",
  "timeline_field": "",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_sidebar": 0,
  "hide_copy": 0,
  "allow_import": 1,
  "allow_auto_repeat": 0,
  "has_web_view": 0,
  "allow_guest_to_view": 0,
  "index_web_pages_for_search": 1,
  "route": "",
  "is_published_field": "",
  "website_search_field": "",
  "email_template": "",
  "restrict_to_domain": "",
  "document_type": "",
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "category",
      "fieldtype": "Select",
      "label": "Category",
      "options": "\nComplaint Response\nEnquiry Response\nGeneral Communication\nAcknowledgement\nFollow Up\nWelcome",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "channel",
      "fieldtype": "Select",
      "label": "Channel",
      "options": "\nEmail\nSMS\nLetter\nIn Person\nAll",
      "default": "All"
    },
    {
      "fieldname": "content",
      "fieldtype": "Text Editor",
      "label": "Content",
      "reqd": 1
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1",
      "in_list_view": 1
    },
    {
      "fieldname": "section_break_1",
      "fieldtype": "Section Break",
      "label": ""
    },
    {
      "fieldname": "available_variables",
      "fieldtype": "Small Text",
      "label": "Available Variables",
      "description": "Comma-separated variables that can be used in the template, e.g. {{ student_name }}, {{ parent_name }}, {{ date }}"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1,
      "amend": 0,
      "cancel": 0,
      "submit": 0,
      "import": 1,
      "select": 0,
      "level": 0
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}
