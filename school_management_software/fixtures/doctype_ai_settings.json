  "fields": [
    {
      "fieldname": "section_break_provider",
      "fieldtype": "Section Break",
      "label": "AI Provider Configuration"
    },
    {
      "fieldname": "enable_ai",
      "fieldtype": "Check",
      "label": "Enable AI Features",
      "default": "0"
    },
    {
      "fieldname": "provider",
      "fieldtype": "Select",
      "label": "AI Provider",
      "options": "\nOpenAI\nAzure OpenAI\nAnthropic Claude\nGoogle Gemini\nLocal LLM\nOther",
      "default": "OpenAI"
    },
    {
      "fieldname": "api_key",
      "fieldtype": "Password",
      "label": "API Key"
    },
    {
      "fieldname": "api_base_url",
      "fieldtype": "Data",
      "label": "API Base URL",
      "description": "For custom/self-hosted endpoints"
    },
    {
      "fieldname": "model",
      "fieldtype": "Data",
      "label": "Model Name",
      "default": "gpt-4o-mini",
      "description": "e.g. gpt-4o-mini, claude-3-haiku, gemini-pro"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "max_tokens",
      "fieldtype": "Int",
      "label": "Max Tokens",
      "default": "2000"
    },
    {
      "fieldname": "temperature",
      "fieldtype": "Float",
      "label": "Temperature",
      "default": "0.7"
    },
    {
      "fieldname": "section_break_features",
      "fieldtype": "Section Break",
      "label": "Feature Toggles"
    },
    {
      "fieldname": "enable_grading",
      "fieldtype": "Check",
      "label": "AI Grading Assistant",
      "default": "0"
    },
    {
      "fieldname": "enable_content_generation",
      "fieldtype": "Check",
      "label": "AI Content Generation (Quiz, Questions)",
      "default": "0"
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "enable_chatbot",
      "fieldtype": "Check",
      "label": "AI Admin Assistant Chatbot",
      "default": "0"
    },
    {
      "fieldname": "enable_report_card_remarks",
      "fieldtype": "Check",
      "label": "AI Report Card Remarks",
      "default": "0"
    },
    {
      "fieldname": "section_break_limits",
      "fieldtype": "Section Break",
      "label": "Rate Limits"
    },
    {
      "fieldname": "requests_per_minute",
      "fieldtype": "Int",
      "label": "Requests Per Minute",
      "default": "30"
    },
    {
      "fieldname": "daily_request_limit",
      "fieldtype": "Int",
      "label": "Daily Request Limit",
      "default": "1000"
    }
  ],
  "permissions": [
