{
  "doctype": "DocType",
  "name": "Call Log",
  "module": "Education",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "is_calendar_and_gantt": 0,
  "editable_grid": 1,
  "quick_entry": 0,
  "track_changes": 0,
  "track_seen": 0,
  "track_views": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "Expression",
  "autoname": "CALL-.YYYY.-.#####",
  "allow_rename": 1,
  "description": "Track incoming and outgoing phone calls",
  "title_field": "caller_name",
  "search_fields": "caller_name,phone_number,purpose",
  "sort_field": "modified",
  "sort_order": "DESC",
  "default_view": "List",
  "icon": "",
  "image_field": "",
  "timeline_field": "",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_sidebar": 0,
  "hide_copy": 0,
  "allow_import": 1,
  "allow_auto_repeat": 0,
  "has_web_view": 0,
  "allow_guest_to_view": 0,
  "index_web_pages_for_search": 1,
  "route": "",
  "is_published_field": "",
  "website_search_field": "",
  "email_template": "",
  "restrict_to_domain": "",
  "document_type": "",
  "fields": [
    {
      "fieldname": "call_date",
      "fieldtype": "Date",
      "label": "Call Date",
      "default": "Today",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "call_time",
      "fieldtype": "Time",
      "label": "Call Time",
      "reqd": 1
    },
    {
      "fieldname": "direction",
      "fieldtype": "Select",
      "label": "Direction",
      "options": "\nIncoming\nOutgoing",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "caller_name",
      "fieldtype": "Data",
      "label": "Caller/Recipient Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "phone_number",
      "fieldtype": "Data",
      "label": "Phone Number",
      "options": "Phone",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "purpose",
      "fieldtype": "Select",
      "label": "Purpose",
      "options": "\nAdmission Enquiry\nGeneral Query\nComplaint\nParent Communication\nFollow Up\nOther",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "duration_minutes",
      "fieldtype": "Int",
      "label": "Duration (Minutes)"
    },
    {
      "fieldname": "staff_member",
      "fieldtype": "Link",
      "label": "Handled By",
      "options": "User",
      "reqd": 1
    },
    {
      "fieldname": "section_break_2",
      "fieldtype": "Section Break",
      "label": ""
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Call Notes"
    },
    {
      "fieldname": "follow_up_required",
      "fieldtype": "Check",
      "label": "Follow Up Required",
      "default": "0"
    },
    {
      "fieldname": "follow_up_date",
      "fieldtype": "Date",
      "label": "Follow Up Date"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Completed\nFollow Up\nResolved",
      "default": "Completed"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1,
      "amend": 0,
      "cancel": 0,
      "submit": 0,
      "import": 1,
      "select": 0,
      "level": 0
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}
