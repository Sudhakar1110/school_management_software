{
  "doctype": "DocType",
  "name": "Question Bank",
  "module": "Education",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "is_calendar_and_gantt": 0,
  "editable_grid": 1,
  "quick_entry": 0,
  "track_changes": 0,
  "track_seen": 0,
  "track_views": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "Expression",
  "autoname": "QB-.YYYY.-.#####",
  "allow_rename": 1,
  "description": "Question bank for creating quizzes, worksheets, and assessments",
  "title_field": "question",
  "search_fields": "question,subject,chapter",
  "sort_field": "modified",
  "sort_order": "DESC",
  "default_view": "List",
  "icon": "",
  "image_field": "",
  "timeline_field": "",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_sidebar": 0,
  "hide_copy": 0,
  "allow_import": 1,
  "allow_auto_repeat": 0,
  "has_web_view": 0,
  "allow_guest_to_view": 0,
  "index_web_pages_for_search": 1,
  "route": "",
  "is_published_field": "",
  "website_search_field": "",
  "email_template": "",
  "restrict_to_domain": "",
  "document_type": "",
  "fields": [
    {
      "fieldname": "question",
      "fieldtype": "Text Editor",
      "label": "Question",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "question_type",
      "fieldtype": "Select",
      "label": "Question Type",
      "options": "\nMultiple Choice\nTrue/False\nShort Answer\nLong Answer\nFill in the Blank\nMatch the Following\nEssay",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "subject",
      "fieldtype": "Link",
      "label": "Subject",
      "options": "Course",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "chapter",
      "fieldtype": "Data",
      "label": "Chapter/Topic",
      "in_list_view": 1
    },
    {
      "fieldname": "difficulty",
      "fieldtype": "Select",
      "label": "Difficulty Level",
      "options": "\nEasy\nMedium\nHard",
      "default": "Medium",
      "in_list_view": 1
    },
    {
      "fieldname": "marks",
      "fieldtype": "Int",
      "label": "Marks",
      "default": "1"
    },
    {
      "fieldname": "board",
      "fieldtype": "Select",
      "label": "Board/Curriculum",
      "options": "\nCBSE\nICSE\nState Board\nInternational\nCambridge\nIB\nOther",
      "in_list_view": 1
    },
    {
      "fieldname": "grade",
      "fieldtype": "Link",
      "label": "Grade/Class",
      "options": "Program",
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "options",
      "fieldtype": "Small Text",
      "label": "Options",
      "description": "For MCQ: one option per line. For Match: pairs separated by pipe, e.g. A | 1"
    },
    {
      "fieldname": "correct_answer",
      "fieldtype": "Small Text",
      "label": "Correct Answer",
      "reqd": 1
    },
    {
      "fieldname": "explanation",
      "fieldtype": "Text Editor",
      "label": "Explanation/Solution"
    },
    {
      "fieldname": "tags",
      "fieldtype": "Data",
      "label": "Tags",
      "description": "Comma-separated tags for search and filtering"
    },
    {
      "fieldname": "section_break_2",
      "fieldtype": "Section Break",
      "label": ""
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1",
      "in_list_view": 1
    },
    {
      "fieldname": "usage_count",
      "fieldtype": "Int",
      "label": "Usage Count",
      "read_only": 1,
      "default": "0"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1,
      "amend": 0,
      "cancel": 0,
      "submit": 0,
      "import": 1,
      "select": 0,
      "level": 0
    },
    {
      "role": "Instructor",
      "create": 1,
      "delete": 0,
      "email": 0,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 1,
      "amend": 0,
      "cancel": 0,
      "submit": 0,
      "import": 0,
      "select": 0,
      "level": 0
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}
