  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Assignment Title",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "course",
      "fieldtype": "Link",
      "label": "Course/Subject",
      "options": "Course",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "student_group",
      "fieldtype": "Link",
      "label": "Student Group",
      "options": "Student Group",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "instructor",
      "fieldtype": "Link",
      "label": "Instructor",
      "options": "Instructor"
    },
    {
      "fieldname": "due_date",
      "fieldtype": "Datetime",
      "label": "Due Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "max_score",
      "fieldtype": "Float",
      "label": "Maximum Score",
      "default": "100"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "submission_type",
      "fieldtype": "Select",
      "label": "Submission Type",
      "options": "\nFile Upload\nText Entry\nOnline Quiz\nBoth (File + Text)\nIn Person",
      "default": "File Upload",
      "in_list_view": 1
    },
    {
      "fieldname": "description",
      "fieldtype": "Text Editor",
      "label": "Assignment Description"
    },
    {
      "fieldname": "instructions",
      "fieldtype": "Small Text",
      "label": "Instructions"
    },
    {
      "fieldname": "section_break_2",
      "fieldtype": "Section Break",
      "label": "Grading"
    },
    {
      "fieldname": "rubric",
      "fieldtype": "Table",
      "label": "Rubric",
      "options": "Assignment Rubric"
    },
    {
      "fieldname": "passing_score",
      "fieldtype": "Float",
      "label": "Passing Score"
    },
    {
      "fieldname": "section_break_3",
      "fieldtype": "Section Break",
      "label": "Submissions"
    },
    {
      "fieldname": "submissions",
      "fieldtype": "Table",
      "label": "Student Submissions",
      "options": "Assignment Submission"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "\nDraft\nPublished\nGrading\nClosed",
      "default": "Draft",
      "in_list_view": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
