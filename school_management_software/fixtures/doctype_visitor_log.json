{
  "doctype": "DocType",
  "name": "Visitor Log",
  "module": "Education",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "is_calendar_and_gantt": 0,
  "editable_grid": 1,
  "quick_entry": 0,
  "track_changes": 0,
  "track_seen": 0,
  "track_views": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "Expression",
  "autoname": "VIS-.YYYY.-.#####",
  "allow_rename": 1,
  "description": "Track visitor entry and exit at school premises",
  "title_field": "visitor_name",
  "search_fields": "visitor_name,contact_number,whom_to_meet,purpose",
  "sort_field": "modified",
  "sort_order": "DESC",
  "default_view": "List",
  "icon": "",
  "image_field": "",
  "timeline_field": "",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_sidebar": 0,
  "hide_copy": 0,
  "allow_import": 1,
  "allow_auto_repeat": 0,
  "has_web_view": 0,
  "allow_guest_to_view": 0,
  "index_web_pages_for_search": 1,
  "route": "",
  "is_published_field": "",
  "website_search_field": "",
  "email_template": "",
  "restrict_to_domain": "",
  "document_type": "",
  "fields": [
    {
      "fieldname": "date",
      "fieldtype": "Date",
      "label": "Date",
      "default": "Today",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "visitor_name",
      "fieldtype": "Data",
      "label": "Visitor Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "contact_number",
      "fieldtype": "Data",
      "label": "Contact Number",
      "options": "Phone",
      "reqd": 1
    },
    {
      "fieldname": "email",
      "fieldtype": "Data",
      "label": "Email",
      "options": "Email"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "purpose",
      "fieldtype": "Select",
      "label": "Purpose",
      "options": "\nMeeting\nParent Visit\nDelivery\nInterview\nEvent\nMaintenance\nOther",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "whom_to_meet",
      "fieldtype": "Data",
      "label": "Whom To Meet",
      "in_list_view": 1
    },
    {
      "fieldname": "department",
      "fieldtype": "Link",
      "label": "Department",
      "options": "Department"
    },
    {
      "fieldname": "section_break_2",
      "fieldtype": "Section Break",
      "label": "Timing"
    },
    {
      "fieldname": "entry_time",
      "fieldtype": "Time",
      "label": "Entry Time",
      "reqd": 1
    },
    {
      "fieldname": "exit_time",
      "fieldtype": "Time",
      "label": "Exit Time"
    },
    {
      "fieldname": "id_proof_type",
      "fieldtype": "Select",
      "label": "ID Proof Type",
      "options": "\nAadhaar\nDriving License\nPassport\nVoter ID\nCollege ID\nOther"
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "id_proof_number",
      "fieldtype": "Data",
      "label": "ID Proof Number"
    },
    {
      "fieldname": "vehicle_number",
      "fieldtype": "Data",
      "label": "Vehicle Number"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Checked In\nChecked Out",
      "default": "Checked In",
      "in_list_view": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1,
      "amend": 0,
      "cancel": 0,
      "submit": 0,
      "import": 1,
      "select": 0,
      "level": 0
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}
