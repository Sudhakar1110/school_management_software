{
  "doctype": "DocType",
  "name": "Alumni Record",
  "module": "Education",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "is_calendar_and_gantt": 0,
  "editable_grid": 1,
  "quick_entry": 0,
  "track_changes": 0,
  "track_seen": 0,
  "track_views": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "By \"Naming Series\" field",
  "autoname": "naming_series:",
  "allow_rename": 1,
  "description": "Record of graduated students for alumni management",
  "title_field": "student_name",
  "search_fields": "student_name,current_organization",
  "sort_field": "modified",
  "sort_order": "DESC",
  "default_view": "List",
  "icon": "",
  "image_field": "",
  "timeline_field": "",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_sidebar": 0,
  "hide_copy": 0,
  "allow_import": 1,
  "allow_auto_repeat": 0,
  "has_web_view": 1,
  "allow_guest_to_view": 0,
  "index_web_pages_for_search": 1,
  "route": "alumni",
  "is_published_field": "is_active",
  "website_search_field": "student_name",
  "email_template": "",
  "restrict_to_domain": "",
  "document_type": "",
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Naming Series",
      "options": "ALM-.YYYY.-\nALM-.#",
      "default": "ALM-.YYYY.-",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "student",
      "fieldtype": "Link",
      "label": "Student",
      "options": "Custom Student",
      "in_list_view": 1
    },
    {
      "fieldname": "student_name",
      "fieldtype": "Data",
      "label": "Student Name",
      "reqd": 1,
      "in_list_view": 1,
      "fetch_from": "student.student_name"
    },
    {
      "fieldname": "student_email",
      "fieldtype": "Data",
      "label": "Student Email",
      "options": "Email",
      "fetch_from": "student.student_email_id"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "graduation_year",
      "fieldtype": "Int",
      "label": "Graduation Year",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "program",
      "fieldtype": "Link",
      "label": "Program",
      "options": "Program",
      "fetch_from": "student.program"
    },
    {
      "fieldname": "batch",
      "fieldtype": "Link",
      "label": "Batch",
      "options": "Student Batch Name"
    },
    {
      "fieldname": "section_break_2",
      "fieldtype": "Section Break",
      "label": "Current Information"
    },
    {
      "fieldname": "current_occupation",
      "fieldtype": "Data",
      "label": "Current Occupation",
      "in_list_view": 1
    },
    {
      "fieldname": "current_organization",
      "fieldtype": "Data",
      "label": "Current Organization",
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_3",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "phone",
      "fieldtype": "Data",
      "label": "Phone",
      "options": "Phone"
    },
    {
      "fieldname": "address",
      "fieldtype": "Text",
      "label": "Address"
    },
    {
      "fieldname": "linkedin_url",
      "fieldtype": "Data",
      "label": "LinkedIn URL"
    },
    {
      "fieldname": "section_break_4",
      "fieldtype": "Section Break",
      "label": ""
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1",
      "in_list_view": 1
    },
    {
      "fieldname": "newsletter_opt_in",
      "fieldtype": "Check",
      "label": "Newsletter Opt In",
      "default": "1"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1,
      "amend": 0,
      "cancel": 0,
      "submit": 0,
      "import": 1,
      "select": 0,
      "level": 0
    },
    {
      "role": "Education Manager",
      "create": 1,
      "delete": 0,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1,
      "amend": 0,
      "cancel": 0,
      "submit": 0,
      "import": 0,
      "select": 0,
      "level": 0
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}
