{
  "doctype": "DocType",
  "name": "AI Settings",
  "module": "School Management Software",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 1,
  "is_tree": 0,
  "editable_grid": 0,
  "track_changes": 0,
  "track_seen": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "By fieldname",
  "autoname": "field:setting_name",
  "allow_rename": 1,
  "description": "Configure AI provider settings for grading, content generation, chatbot, and report card remarks",
  "title_field": "setting_name",
  "search_fields": "",
  "sort_field": "modified",
  "sort_order": "DESC",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "index_web_pages_for_search": 1,
  "fields": [
    {
      "fieldname": "setting_name",
      "fieldtype": "Data",
      "label": "Setting Name",
      "default": "AI Configuration",
      "reqd": 1
    },
    {
      "fieldname": "enable_ai",
      "fieldtype": "Check",
      "label": "Enable AI Features",
      "default": "0"
    },
    {
      "fieldname": "section_break_provider",
      "fieldtype": "Section Break",
      "label": "AI Provider Configuration"
    },
    {
      "fieldname": "provider",
      "fieldtype": "Select",
      "label": "AI Provider",
      "options": "OpenAI\nAnthropic Claude",
      "default": "OpenAI",
      "reqd": 1
    },
    {
      "fieldname": "api_key",
      "fieldtype": "Password",
      "label": "API Key"
    },
    {
      "fieldname": "column_break_endpoint",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "api_base_url",
      "fieldtype": "Data",
      "label": "API Base URL",
      "description": "Optional. Leave empty to use default provider URL."
    },
    {
      "fieldname": "model",
      "fieldtype": "Data",
      "label": "Model Name",
      "default": "gpt-4o-mini",
      "reqd": 1
    },
    {
      "fieldname": "max_tokens",
      "fieldtype": "Int",
      "label": "Max Tokens",
      "default": "2000"
    },
    {
      "fieldname": "temperature",
      "fieldtype": "Float",
      "label": "Temperature",
      "default": "0.7"
    },
    {
      "fieldname": "section_break_features",
      "fieldtype": "Section Break",
      "label": "Enable AI Features"
    },
    {
      "fieldname": "enable_chatbot",
      "fieldtype": "Check",
      "label": "Enable AI Assistant Chatbot",
      "default": "0",
      "depends_on": "eval:doc.enable_ai"
    },
    {
      "fieldname": "enable_grading",
      "fieldtype": "Check",
      "label": "Enable AI Grading",
      "default": "0",
      "depends_on": "eval:doc.enable_ai"
    },
    {
      "fieldname": "column_break_features2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "enable_content_generation",
      "fieldtype": "Check",
      "label": "Enable Content Generation",
      "default": "0",
      "depends_on": "eval:doc.enable_ai"
    },
    {
      "fieldname": "enable_report_card_remarks",
      "fieldtype": "Check",
      "label": "Enable Report Card Remarks",
      "default": "0",
      "depends_on": "eval:doc.enable_ai"
    },
    {
      "fieldname": "section_break_limits",
      "fieldtype": "Section Break",
      "label": "Usage Limits"
    },
    {
      "fieldname": "daily_request_limit",
      "fieldtype": "Int",
      "label": "Daily Request Limit",
      "default": "1000"
    },
    {
      "fieldname": "column_break_cost",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "cost_per_request",
      "fieldtype": "Currency",
      "label": "Cost Per Request",
      "default": "0.01"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}
