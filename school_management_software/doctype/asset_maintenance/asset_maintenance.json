{
  "doctype": "DocType",
  "name": "Asset Maintenance",
  "module": "School Assets",
  "custom": 1,
  "is_submittable": 1,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "editable_grid": 0,
  "track_changes": 1,
  "track_seen": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "By fieldname",
  "autoname": "field:maintenance_id",
  "allow_rename": 1,
  "description": "Track maintenance and repair history for school assets",
  "title_field": "asset_name",
  "search_fields": "asset_name,maintenance_id,asset_code",
  "sort_field": "modified",
  "sort_order": "DESC",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "index_web_pages_for_search": 1,
  "fields": [
    {
      "fieldname": "maintenance_id",
      "fieldtype": "Data",
      "label": "Maintenance ID",
      "reqd": 1,
      "unique": 1
    },
    {
      "fieldname": "asset_code",
      "fieldtype": "Link",
      "label": "Asset",
      "options": "Asset Register",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "asset_name",
      "fieldtype": "Read Only",
      "label": "Asset Name",
      "fetch_from": "asset_code.asset_name"
    },
    {
      "fieldname": "category",
      "fieldtype": "Read Only",
      "label": "Category",
      "fetch_from": "asset_code.category"
    },
    {
      "fieldname": "column_break_schedule",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "maintenance_type",
      "fieldtype": "Select",
      "label": "Maintenance Type",
      "options": "Preventive\nCorrective\nEmergency\nScheduled Service",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "maintenance_date",
      "fieldtype": "Date",
      "label": "Maintenance Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "completed_date",
      "fieldtype": "Date",
      "label": "Completed Date"
    },
    {
      "fieldname": "section_break_details",
      "fieldtype": "Section Break",
      "label": "Service Details"
    },
    {
      "fieldname": "issue_description",
      "fieldtype": "Text Editor",
      "label": "Issue Description",
      "reqd": 1
    },
    {
      "fieldname": "work_performed",
      "fieldtype": "Text Editor",
      "label": "Work Performed"
    },
    {
      "fieldname": "column_break_costs",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "service_provider",
      "fieldtype": "Data",
      "label": "Service Provider"
    },
    {
      "fieldname": "cost",
      "fieldtype": "Currency",
      "label": "Maintenance Cost"
    },
    {
      "fieldname": "vendor_invoice",
      "fieldtype": "Attach",
      "label": "Vendor Invoice"
    },
    {
      "fieldname": "section_break_status",
      "fieldtype": "Section Break",
      "label": "Status"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Pending\nIn Progress\nCompleted\nCancelled",
      "default": "Pending",
      "in_list_view": 1
    },
    {
      "fieldname": "next_maintenance_date",
      "fieldtype": "Date",
      "label": "Next Scheduled Maintenance"
    },
    {
      "fieldname": "performed_by",
      "fieldtype": "Link",
      "label": "Performed By",
      "options": "Employee"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Text",
      "label": "Additional Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 0
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}
