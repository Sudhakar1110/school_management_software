{
  "doctype": "DocType",
  "name": "Call Log",
  "module": "School Management Software",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "editable_grid": 0,
  "track_changes": 0,
  "track_seen": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "Auto",
  "autoname": "",
  "allow_rename": 1,
  "description": "",
  "title_field": "",
  "search_fields": "caller_name,contact_number",
  "sort_field": "modified",
  "sort_order": "DESC",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "index_web_pages_for_search": 1,
  "fields": [
    {
      "fieldname": "caller_name",
      "fieldtype": "Data",
      "label": "Caller Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "contact_number",
      "fieldtype": "Data",
      "label": "Contact Number",
      "reqd": 1
    },
    {
      "fieldname": "call_type",
      "fieldtype": "Select",
      "label": "Call Type",
      "options": "Incoming\nOutgoing",
      "reqd": 1
    },
    {
      "fieldname": "purpose",
      "fieldtype": "Data",
      "label": "Purpose"
    },
    {
      "fieldname": "call_date",
      "fieldtype": "Date",
      "label": "Date",
      "reqd": 1,
      "default": "Today",
      "in_list_view": 1
    },
    {
      "fieldname": "call_time",
      "fieldtype": "Time",
      "label": "Time"
    },
    {
      "fieldname": "duration_minutes",
      "fieldtype": "Int",
      "label": "Duration (min)"
    },
    {
      "fieldname": "call_to",
      "fieldtype": "Data",
      "label": "Call To"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    },
    {
      "fieldname": "follow_up_required",
      "fieldtype": "Check",
      "label": "Follow Up Required"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1
    },
    {
      "role": "Student",
      "create": 0,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 1
    },
    {
      "role": "Guardian",
      "create": 0,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 0
    },
    {
      "role": "Instructor",
      "create": 1,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 1
    }
  ],
  "actions": [],
  "links": [],
  "states": []
