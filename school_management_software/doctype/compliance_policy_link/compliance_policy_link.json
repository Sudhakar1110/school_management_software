{
  "doctype": "DocType",
  "name": "Compliance Policy Link",
  "module": "School Compliance",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "editable_grid": 0,
  "track_changes": 0,
  "track_seen": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "Random",
  "autoname": "hash",
  "allow_rename": 1,
  "description": "Linked policies for compliance certifications",
  "title_field": "policy_name",
  "search_fields": "policy_name",
  "sort_field": "modified",
  "sort_order": "DESC",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "index_web_pages_for_search": 1,
  "fields": [
    {
      "fieldname": "policy_name",
      "fieldtype": "Data",
      "label": "Policy Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "policy_document",
      "fieldtype": "Attach",
      "label": "Policy Document"
    },
    {
      "fieldname": "policy_status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nApproved\nUnder Review\nSuperseded",
      "default": "Approved"
    },
    {
      "fieldname": "effective_date",
      "fieldtype": "Date",
      "label": "Effective Date"
    },
    {
      "fieldname": "review_date",
      "fieldtype": "Date",
      "label": "Next Review Date"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1
    },
    {
      "role": "Education Manager",
      "create": 1,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 1
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}
