{
  "doctype": "DocType",
  "name": "Biometric Device",
  "module": "School Management Software",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "editable_grid": 0,
  "track_changes": 0,
  "track_seen": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "By fieldname",
  "autoname": "field:device_name",
  "allow_rename": 1,
  "description": "",
  "title_field": "device_name",
  "search_fields": "",
  "sort_field": "modified",
  "sort_order": "DESC",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "index_web_pages_for_search": 1,
  "fields": [
    {
      "fieldname": "device_name",
      "fieldtype": "Data",
      "label": "Device Name",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "device_type",
      "fieldtype": "Select",
      "label": "Device Type",
      "options": "Fingerprint\nRFID\nFace Recognition\nIris",
      "reqd": 1
    },
    {
      "fieldname": "ip_address",
      "fieldtype": "Data",
      "label": "IP Address"
    },
    {
      "fieldname": "port",
      "fieldtype": "Int",
      "label": "Port",
      "default": "80"
    },
    {
      "fieldname": "serial_number",
      "fieldtype": "Data",
      "label": "Serial Number"
    },
    {
      "fieldname": "location",
      "fieldtype": "Data",
      "label": "Location"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Active",
      "default": "1"
    },
    {
      "fieldname": "last_sync",
      "fieldtype": "Datetime",
      "label": "Last Sync",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}