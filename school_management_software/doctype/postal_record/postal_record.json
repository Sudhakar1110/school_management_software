{
  "doctype": "DocType",
  "name": "Postal Record",
  "module": "School Management Software",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "editable_grid": 0,
  "track_changes": 0,
  "track_seen": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "Auto",
  "autoname": "",
  "allow_rename": 1,
  "description": "",
  "title_field": "",
  "search_fields": "sender_recipient,subject",
  "sort_field": "modified",
  "sort_order": "DESC",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "index_web_pages_for_search": 1,
  "fields": [
    {
      "fieldname": "postal_type",
      "fieldtype": "Select",
      "label": "Type",
      "options": "Incoming\nOutgoing\nConfidential",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "sender_recipient",
      "fieldtype": "Data",
      "label": "Sender/Recipient",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "subject",
      "fieldtype": "Data",
      "label": "Subject",
      "reqd": 1
    },
    {
      "fieldname": "date",
      "fieldtype": "Date",
      "label": "Date",
      "reqd": 1,
      "default": "Today"
    },
    {
      "fieldname": "reference_number",
      "fieldtype": "Data",
      "label": "Reference Number"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "attachment",
      "fieldtype": "Attach",
      "label": "Attachment"
    },
    {
      "fieldname": "delivery_mode",
      "fieldtype": "Select",
      "label": "Delivery Mode",
      "options": "Courier\nPost\nHand Delivery\nEmail"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Pending\nDelivered\nAcknowledged",
      "default": "Pending"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1
    },
    {
      "role": "Student",
      "create": 0,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 1
    },
    {
      "role": "Guardian",
      "create": 0,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 0
    },
    {
      "role": "Instructor",
      "create": 1,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 1
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}