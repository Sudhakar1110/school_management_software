{
  "doctype": "DocType",
  "name": "Event Participant",
  "module": "School Management Software",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "is_calendar_and_gantt": 0,
  "editable_grid": 1,
  "quick_entry": 0,
  "track_changes": 0,
  "track_seen": 0,
  "track_views": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "",
  "autoname": "hash",
  "allow_rename": 1,
  "description": "",
  "title_field": "",
  "search_fields": "",
  "sort_field": "modified",
  "sort_order": "DESC",
  "default_view": "",
  "icon": "",
  "image_field": "",
  "timeline_field": "",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_sidebar": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "has_web_view": 0,
  "allow_guest_to_view": 0,
  "index_web_pages_for_search": 1,
  "route": "",
  "is_published_field": "",
  "website_search_field": "",
  "email_template": "",
  "restrict_to_domain": "",
  "document_type": "",
  "fields": [
    {
      "fieldname": "participant_type",
      "fieldtype": "Select",
      "label": "Participant Type",
      "options": "Student\nEmployee\nParent\nGuest",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "student",
      "fieldtype": "Link",
      "label": "Student",
      "options": "Student",
      "depends_on": "eval:doc.participant_type==\"Student\""
    },
    {
      "fieldname": "employee",
      "fieldtype": "Link",
      "label": "Employee",
      "options": "Employee",
      "depends_on": "eval:doc.participant_type==\"Employee\""
    },
    {
      "fieldname": "parent_record",
      "fieldtype": "Link",
      "label": "Parent",
      "options": "Guardian Profile",
      "depends_on": "eval:doc.participant_type==\"Parent\""
    },
    {
      "fieldname": "guest_name",
      "fieldtype": "Data",
      "label": "Guest Name",
      "in_list_view": 1,
      "depends_on": "eval:doc.participant_type==\"Guest\""
    },
    {
      "fieldname": "email",
      "fieldtype": "Data",
      "label": "Email"
    },
    {
      "fieldname": "mobile_number",
      "fieldtype": "Data",
      "label": "Mobile Number"
    },
    {
      "fieldname": "attendance",
      "fieldtype": "Select",
      "label": "Attendance",
      "options": "Pending\nPresent\nAbsent",
      "default": "Pending",
      "in_list_view": 1
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1,
      "amend": 0,
      "cancel": 0,
      "submit": 0,
      "import": 0,
      "select": 0,
      "level": 0
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}