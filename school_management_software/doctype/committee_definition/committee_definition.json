{
  "doctype": "DocType",
  "name": "Committee Definition",
  "module": "School Governance",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "editable_grid": 0,
  "track_changes": 1,
  "track_seen": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "By fieldname",
  "autoname": "field:committee_name",
  "allow_rename": 1,
  "description": "Define committees and governing bodies for the institution",
  "title_field": "committee_name",
  "search_fields": "committee_name,committee_type",
  "sort_field": "modified",
  "sort_order": "DESC",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "index_web_pages_for_search": 1,
