{
  "doctype": "DocType",
  "name": "Response Template",
  "module": "School Management Software",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "editable_grid": 0,
  "track_changes": 0,
  "track_seen": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "By fieldname",
  "autoname": "field:template_title",
  "allow_rename": 1,
  "description": "",
  "title_field": "template_title",
  "search_fields": "",
  "sort_field": "modified",
  "sort_order": "DESC",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "index_web_pages_for_search": 1,
  "fields": [
    {
      "fieldname": "template_title",
      "fieldtype": "Data",
      "label": "Template Title",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "template_type",
      "fieldtype": "Select",
      "label": "Type",
      "options": "Email\nSMS\nWhatsApp\nLetter",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "category",
      "fieldtype": "Select",
      "label": "Category",
      "options": "General\nComplaint\nEnquiry\nFollow-up\nNotice",
      "default": "General"
    },
    {
      "fieldname": "subject",
      "fieldtype": "Data",
      "label": "Subject"
    },
    {
      "fieldname": "body",
      "fieldtype": "Text Editor",
      "label": "Body",
      "reqd": 1
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Active",
      "default": "1"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1
    },
    {
      "role": "Student",
      "create": 0,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 1
    },
    {
      "role": "Guardian",
      "create": 0,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 0
    },
    {
      "role": "Instructor",
      "create": 1,
      "delete": 0,
      "email": 0,
      "export": 0,
      "print": 1,
      "read": 1,
      "report": 0,
      "share": 0,
      "write": 1
    }
  ],
