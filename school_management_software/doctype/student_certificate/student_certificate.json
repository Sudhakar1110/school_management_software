{
  "doctype": "DocType",
  "name": "Student Certificate",
  "module": "Custom",
  "custom": 1,
  "is_submittable": 0,
  "is_child_table": 0,
  "is_single": 0,
  "is_tree": 0,
  "is_calendar_and_gantt": 0,
  "editable_grid": 1,
  "quick_entry": 0,
  "track_changes": 0,
  "track_seen": 0,
  "track_views": 0,
  "beta": 0,
  "is_virtual": 0,
  "naming_rule": "By \"Naming Series\" field",
  "autoname": "naming_series:",
  "allow_rename": 1,
  "description": "",
  "title_field": "",
  "search_fields": "",
  "sort_field": "modified",
  "sort_order": "DESC",
  "default_view": "",
  "icon": "",
  "image_field": "",
  "timeline_field": "",
  "engine": "InnoDB",
  "show_preview_popup": 0,
  "max_attachments": 0,
  "hide_sidebar": 0,
  "hide_copy": 0,
  "allow_import": 0,
  "allow_auto_repeat": 0,
  "has_web_view": 0,
  "allow_guest_to_view": 0,
  "index_web_pages_for_search": 1,
  "route": "",
  "is_published_field": "",
  "website_search_field": "",
  "email_template": "",
  "restrict_to_domain": "",
  "document_type": "",
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Naming Series",
      "options": "SCRT-.YYYY.-",
      "default": "SCRT-.YYYY.-",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "student",
      "fieldtype": "Link",
      "label": "Student",
      "options": "Custom Student",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "student_name",
      "fieldtype": "Data",
      "label": "Student Name",
      "read_only": 1,
      "fetch_from": "student.student_name"
    },
    {
      "fieldname": "class",
      "fieldtype": "Data",
      "label": "Class",
      "read_only": 1,
      "fetch_from": "student.class_name"
    },
    {
      "fieldname": "academic_year",
      "fieldtype": "Data",
      "label": "Academic Year",
      "fetch_from": "student.current_academic_year"
    },
    {
      "fieldname": "template",
      "fieldtype": "Link",
      "label": "Template",
      "options": "Certificate Template",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break",
      "label": ""
    },
    {
      "fieldname": "generated_on",
      "fieldtype": "Datetime",
      "label": "Generated On",
      "read_only": 1
    },
    {
      "fieldname": "generated_by",
      "fieldtype": "Link",
      "label": "Generated By",
      "options": "User",
      "read_only": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nIssued\nCancelled"
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Purpose"
    },
    {
      "fieldname": "section_break_1",
      "fieldtype": "Section Break",
      "label": ""
    },
    {
      "fieldname": "certificate_pdf",
      "fieldtype": "Attach",
      "label": "Certificate PDF",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "share": 1,
      "write": 1,
      "amend": 0,
      "cancel": 0,
      "submit": 0,
      "import": 0,
      "select": 0,
      "level": 0
    }
  ],
  "actions": [],
  "links": [],
  "states": []
}